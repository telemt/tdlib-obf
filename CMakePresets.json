{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 10,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "displayName": "Default RelWithDebInfo",
      "description": "Workspace default configure preset used by VS Code CMake Tools.",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "environment": {
        "CMAKE_BUILD_PARALLEL_LEVEL": "14",
        "CC": "gcc-15",
        "CXX": "g++-15"
      },
      "cacheVariables": {
        "BUILD_SHARED_LIBS": "ON",
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "TD_ENABLE_BENCHMARKS": "OFF",
        "TD_ENABLE_LLD": "ON",
        "TD_ENABLE_NATIVE_ARCH": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "default-all",
      "displayName": "Default Build (all targets)",
      "configurePreset": "default",
      "jobs": 14
    }
  ],
  "testPresets": [
    {
      "name": "default-ctest",
      "displayName": "Default CTest (all tests)",
      "configurePreset": "default",
      "execution": {
        "jobs": 14
      },
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "sqlite-vendor-smoke",
      "configurePreset": "default",
      "output": {
        "outputOnFailure": true
      },
      "filter": {
        "include": {
          "name": "^Test_DB_sqlite_vendor_wrapper_surface_contract$"
        }
      }
    }
  ]
}