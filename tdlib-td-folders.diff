+bool Session::resolve_need_create_main_auth_key(bool can_destroy_auth_key, bool need_main_auth_key, double now,
+                                                double reauth_not_before) {
+  return !can_destroy_auth_key && need_main_auth_key && now >= reauth_not_before;
+}
