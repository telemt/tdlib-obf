+      Op::bytes("\x01\x00"),
+      Op::scope16_begin(),
+      Op::legacy_version_from_profile(),
+      Op::zero_bytes(32),
+      Op::bytes("\x20"),
+      Op::random_bytes(32),
+      Op::cipher_suites_from_profile(),
+      Op::bytes("\x01\x00"),
+      Op::scope16_begin(),
+      Op::grease(2),
+      Op::bytes("\x00\x00"),
+      Op::extensions_from_profile(),
+      Op::grease(3),
+      Op::bytes("\x00\x00"),
